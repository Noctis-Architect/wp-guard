[Unit]
Description=WordPress Scanner (Flask + SocketIO)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/mr-noctis/projects/wp_scanner

# Defaults; override in .env (WP_SCANNER_SECRET, WP_SCANNER_PORT)
Environment=WP_SCANNER_PORT=5000
EnvironmentFile=-/home/mr-noctis/projects/wp_scanner/.env

ExecStart=/home/mr-noctis/projects/wp_scanner/venv/bin/gunicorn \
    --worker-class eventlet \
    -w 1 \
    --bind 0.0.0.0:${WP_SCANNER_PORT} \
    --timeout 120 \
    --access-logfile - \
    --error-logfile - \
    app:app

Restart=always
RestartSec=5
KillMode=mixed
TimeoutStopSec=30

[Install]
WantedBy=default.target
